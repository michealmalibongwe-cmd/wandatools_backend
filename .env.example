# WandaTools Backend - Environment Variables Template
# Copy this to .env and fill in your values

# ═════════════════════════════════════════════════════════════
# DATABASE
# ═════════════════════════════════════════════════════════════
# Local Development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wandatools_db

# Production (Render.com example)
# DATABASE_URL=postgresql://user:password@dpg-xyz.render.internal:5432/wandatools_db


# ═════════════════════════════════════════════════════════════
# SECURITY
# ═════════════════════════════════════════════════════════════
# Generate a strong secret key:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=dev-secret-key-change-in-production-min-32-chars-required!!


# ═════════════════════════════════════════════════════════════
# ENVIRONMENT & DEBUG
# ═════════════════════════════════════════════════════════════
# Options: development, staging, production
ENVIRONMENT=development
DEBUG=true


# ═════════════════════════════════════════════════════════════
# API CONFIGURATION
# ═════════════════════════════════════════════════════════════
API_PREFIX=/api/v1


# ═════════════════════════════════════════════════════════════
# CORS (Frontend URLs)
# ═════════════════════════════════════════════════════════════
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,https://wandatools.com


# ═════════════════════════════════════════════════════════════
# EMAIL CONFIGURATION (for notifications)
# ═════════════════════════════════════════════════════════════
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SUPPORT_EMAIL=support@wandatools.com


# ═════════════════════════════════════════════════════════════
# AI CONFIGURATION (Future)
# ═════════════════════════════════════════════════════════════
AI_API_KEY=your-ai-api-key-here
AI_API_URL=https://api.openai.com/v1


# ═════════════════════════════════════════════════════════════
# FILE UPLOAD
# ═════════════════════════════════════════════════════════════
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760  # 10 MB in bytes


# ═════════════════════════════════════════════════════════════
# RATE LIMITING
# ═════════════════════════════════════════════════════════════
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60  # seconds


# ═════════════════════════════════════════════════════════════
# TOKENS EXPIRATION
# ═════════════════════════════════════════════════════════════
ACCESS_TOKEN_EXPIRE_MINUTES=1440  # 24 hours
REFRESH_TOKEN_EXPIRE_DAYS=7


# ═════════════════════════════════════════════════════════════
# NOTES
# ═════════════════════════════════════════════════════════════
# - Never commit .env file to version control
# - In production, use environment variables from your hosting provider
# - Generate strong SECRET_KEY for production
# - Use environment-specific CORS origins
# - Keep SMTP credentials secure
